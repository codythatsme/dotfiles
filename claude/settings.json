{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(bun add:*)",
      "Bash(bun run lint:*)",
      "Bash(bun run format:check:*)",
      "Bash(npx tsc:*)",
      "Bash(bunx tsc:*)",
      "Bash(bun test:*)",
      "Bash(bun run build:mac:*)",
      "Bash(./dist/i-migrate)",
      "Bash(./i-migrate)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git blame:*)",
      "Bash(git remote:*)",
      "Bash(git stash list:*)",
      "Bash(git tag:*)",
      "Bash(git rev-parse:*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(du:*)",
      "Bash(tree:*)",
      "Bash(diff:*)",
      "Bash(which:*)",
      "Bash(pwd:*)",
      "Bash(uname:*)",
      "Bash(sw_vers:*)",
      "Bash(date:*)",
      "Bash(jq:*)",
      "Bash(node --version:*)",
      "Bash(bun --version:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh repo view:*)",
      "Bash(brew list:*)",
      "Bash(brew info:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(.envrc)",
      "Read(secrets/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false,
    "playwright@claude-plugins-official": false,
    "plannotator@plannotator": true
  },
  "extraKnownMarketplaces": {
    "plannotator": {
      "source": {
        "source": "github",
        "repo": "backnotprop/plannotator"
      }
    }
  },
  "effortLevel": "high"
}
